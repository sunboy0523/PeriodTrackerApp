<?xml version="1.0" encoding="utf-8"?>
<ScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="周期统计"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <!-- 统计概览卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="16dp">

                <LinearLayout style="@style/StatsItem">
                    <TextView style="@style/StatsLabel" android:text="平均周期" />
                    <TextView
                        android:id="@+id/tvAvgCycleLength"
                        style="@style/StatsValue"
                        android:text="--" />
                </LinearLayout>

                <LinearLayout style="@style/StatsItem">
                    <TextView style="@style/StatsLabel" android:text="平均经期" />
                    <TextView
                        android:id="@+id/tvAvgPeriodLength"
                        style="@style/StatsValue"
                        android:text="--" />
                </LinearLayout>

                <LinearLayout style="@style/StatsItem">
                    <TextView style="@style/StatsLabel" android:text="记录周期数" />
                    <TextView
                        android:id="@+id/tvTotalRecords"
                        style="@style/StatsValue"
                        android:text="0" />
                </LinearLayout>

                <LinearLayout style="@style/StatsItem">
                    <TextView style="@style/StatsLabel" android:text="周期规律性" />
                    <TextView
                        android:id="@+id/tvCycleRegularity"
                        style="@style/StatsValueSmall"
                        android:text="数据不足" />
                </LinearLayout>
            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 周期长度趋势图 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="周期长度趋势"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartCycleLength"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvNoCycleData"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:gravity="center"
                    android:text="记录更多周期后可查看趋势图"
                    android:textColor="@color/gray"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 经期长度统计图 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="经期长度统计"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chartPeriodLength"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvNoPeriodData"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:gravity="center"
                    android:text="记录更多经期后可查看统计图"
                    android:textColor="@color/gray"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 周期说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="周期小知识"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="• 正常月经周期：21-35天\n• 正常经期长度：3-7天\n• 排卵日：通常在下次月经前14天\n• 排卵期：排卵日前5天到后1天"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="@color/gray_dark" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
